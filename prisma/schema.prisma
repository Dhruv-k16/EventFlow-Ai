generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole        @default(CLIENT)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  eventsOwned    Event[]         @relation("ClientEvents")
  PlannerProfile PlannerProfile?
  RefreshToken   RefreshToken[]
  vendorProfile  Vendor?         @relation("UserToVendor")

  @@index([email])
  @@index([role])
}

model Vendor {
  id                      String                    @id @default(uuid())
  userId                  String                    @unique
  businessName            String
  category                String
  description             String?
  maxEventsPerDay         Int                       @default(2)
  rating                  Decimal                   @default(0) @db.Decimal(3, 2)
  location                String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  delayedDeliveries       Int                       @default(0)
  lastMinuteRequests      Int                       @default(0)
  totalDeliveries         Int                       @default(0)
  totalOrders             Int                       @default(0)
  // ── NEW portfolio & contact fields ─────────────────────────────────────────
  tagline                 String?
  phone                   String?
  email                   String?
  website                 String?
  city                    String?
  priceRange              String?
  totalReviews            Int                       @default(0)
  yearsInBusiness         Int?
  coverImageUrl           String?
  avatarUrl               String?
  services                String[]                  @default([])
  specialties             String[]                  @default([])
  portfolioItems          PortfolioItem[]
  // ───────────────────────────────────────────────────────────────────────────
  bookings                Booking[]
  inventory               InventoryItem[]
  staff                   Staff[]
  user                    User                      @relation("UserToVendor", fields: [userId], references: [id])
  VendorAvailabilityBlock VendorAvailabilityBlock[]

  @@index([category])
  @@index([category, city])
}

// ── NEW MODEL ──────────────────────────────────────────────────────────────────
model PortfolioItem {
  id           String   @id @default(uuid())
  vendorId     String
  title        String
  description  String?
  imageUrl     String?
  eventType    String?
  tags         String[] @default([])
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, displayOrder])
}

model Event {
  id               String            @id @default(uuid())
  name             String
  eventType        String?
  startDate        DateTime
  endDate          DateTime
  isMultiDay       Boolean           @default(false)
  location         String?
  guestCount       Int?
  description      String?
  clientId         String
  plannerId        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  // ── NEW sub-event / function fields ────────────────────────────────────────
  type             EventType         @default(SINGLE)
  parentId         String?
  time             String?
  venueName        String?
  totalBudget      Decimal?          @db.Decimal(12, 2)
  allocatedBudget  Decimal?          @db.Decimal(12, 2)
  parent           Event?            @relation("EventFunctions", fields: [parentId], references: [id])
  functions        Event[]           @relation("EventFunctions")
  // ───────────────────────────────────────────────────────────────────────────
  bookings         Booking[]
  client           User              @relation("ClientEvents", fields: [clientId], references: [id])
  planner          PlannerProfile?   @relation("PlannerEvents", fields: [plannerId], references: [id])
  FinancialSummary FinancialSummary?
  LiveEvent        LiveEvent?
  staffAssignments        StaffAssignment[]
  plannerStaffAssignments PlannerStaffAssignment[] @relation("StaffAssignments")

  @@index([clientId])
  @@index([plannerId])
  @@index([startDate])
  @@index([parentId])
}

model InventoryItem {
  id                  String                @id @default(uuid())
  vendorId            String
  name                String
  description         String?
  totalQuantity       Int                   @default(0)
  basePrice           Decimal               @db.Decimal(12, 2)
  unit                String                @default("per unit")
  imageUrl            String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  hasVariants         Boolean               @default(false)
  bookingItems        BookingItem[]
  InventoryAllocation InventoryAllocation[]
  vendor              Vendor                @relation(fields: [vendorId], references: [id])
  InventoryVariant    InventoryVariant[]

  @@index([vendorId, name])
  @@index([vendorId])
}

model Booking {
  id              String          @id @default(uuid())
  status          BookingStatus   @default(REQUESTED)
  eventId         String
  vendorId        String
  totalCost       Decimal         @default(0) @db.Decimal(12, 2)
  depositPaid     Decimal         @default(0) @db.Decimal(12, 2)
  notes           String?
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  event           Event           @relation(fields: [eventId], references: [id])
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  items           BookingItem[]
  MeetingRecord   MeetingRecord[]

  @@index([vendorId, status])
  @@index([eventId])
  @@index([status])
}

model BookingItem {
  id               String            @id @default(uuid())
  bookingId        String
  inventoryItemId  String
  quantity         Int
  priceAtBooking   Decimal           @db.Decimal(12, 2)
  variantId        String?
  booking          Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem     @relation(fields: [inventoryItemId], references: [id])
  InventoryVariant InventoryVariant? @relation(fields: [variantId], references: [id])

  @@index([bookingId])
  @@index([inventoryItemId])
  @@index([variantId])
}

model Staff {
  id          String            @id @default(uuid())
  vendorId    String
  name        String
  role        String
  wage        Decimal           @db.Decimal(10, 2)
  status      StaffStatus       @default(AVAILABLE)
  phone       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  vendor      Vendor            @relation(fields: [vendorId], references: [id])
  assignments StaffAssignment[]

  @@index([vendorId])
}

model StaffAssignment {
  id        String   @id @default(uuid())
  staffId   String
  eventId   String
  startTime DateTime
  endTime   DateTime
  role      String?
  event     Event    @relation(fields: [eventId], references: [id])
  staff     Staff    @relation(fields: [staffId], references: [id])

  @@index([staffId, startTime, endTime])
  @@index([eventId])
}

model RiskSnapshot {
  id              String   @id @default(uuid())
  riskScore       Int
  factors         Json
  createdAt       DateTime @default(now())
  aiSummary       String?
  alerts          Json?
  recommendations Json?
  role            String   @default("PLANNER")
  targetId        String
  targetType      String
  weatherData     Json?

  @@index([targetId, createdAt])
  @@index([targetId, targetType])
}

model FinancialSummary {
  id               String   @id @default(uuid())
  eventId          String   @unique
  totalRevenue     Decimal  @db.Decimal(12, 2)
  totalCosts       Decimal  @db.Decimal(12, 2)
  projectedProfit  Decimal  @db.Decimal(12, 2)
  depositCollected Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt        DateTime @updatedAt
  Event            Event    @relation(fields: [eventId], references: [id])
}

model Incident {
  id          String    @id @default(uuid())
  liveEventId String
  title       String
  description String?
  severity    String    @default("LOW")
  reportedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  LiveEvent   LiveEvent @relation(fields: [liveEventId], references: [id])

  @@index([liveEventId, severity])
}

model InventoryAllocation {
  id              String        @id @default(uuid())
  inventoryItemId String
  date            DateTime
  allocatedQty    Int           @default(0)
  InventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([inventoryItemId, date])
  @@index([date])
}

model InventoryVariant {
  id                  String                @id @default(uuid())
  itemId              String
  name                String
  sku                 String?
  totalQuantity       Int                   @default(0)
  bookedQuantity      Int                   @default(0)
  priceOverride       Decimal?              @db.Decimal(12, 2)
  color               String?
  material            String?
  dimensions          String?
  attributes          Json?
  imageUrl            String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime  @updatedAt
  BookingItem         BookingItem[]
  InventoryItem       InventoryItem         @relation(fields: [itemId], references: [id])
  VariantAvailability VariantAvailability[]

  @@index([itemId])
  @@index([itemId, name])
}

model LiveEvent {
  id                 String     @id @default(uuid())
  eventId            String     @unique
  isActive           Boolean    @default(true)
  startedAt          DateTime   @default(now())
  concludedAt        DateTime?
  changeRequestCount Int        @default(0)
  Incident           Incident[]
  Event              Event      @relation(fields: [eventId], references: [id])
  LiveTask           LiveTask[]

  @@index([isActive])
}

model LiveTask {
  id          String     @id @default(uuid())
  liveEventId String
  title       String
  description String?
  assignedTo  String?
  scheduledAt DateTime
  status      TaskStatus @default(NOT_STARTED)
  completedAt DateTime?
  delayReason String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime  @updatedAt
  LiveEvent   LiveEvent  @relation(fields: [liveEventId], references: [id])

  @@index([liveEventId, status])
  @@index([scheduledAt])
}

model MeetingRecord {
  id          String        @id @default(uuid())
  bookingId   String
  phase       Int
  status      MeetingStatus @default(SCHEDULED)
  scheduledAt DateTime
  completedAt DateTime?
  meetingLink String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime  @updatedAt
  Booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model PlannerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  businessName    String?
  maxEventsPerDay Int      @default(3)
  bio             String?
  yearsExperience Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime  @updatedAt
  eventsPlanned        Event[]              @relation("PlannerEvents")
  staff           PlannerStaff[]
  User            User     @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model VariantAvailability {
  id               String           @id @default(uuid())
  variantId        String
  date             DateTime
  bookedQty        Int              @default(0)
  holdQty          Int              @default(0)
  InventoryVariant InventoryVariant @relation(fields: [variantId], references: [id])

  @@unique([variantId, date])
  @@index([date])
}

model VendorAvailabilityBlock {
  id        String   @id @default(uuid())
  vendorId  String
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())
  Vendor    Vendor   @relation(fields: [vendorId], references: [id])

  @@index([vendorId, startDate, endDate])
}

// ── ENUMS (all original preserved) ────────────────────────────────────────────

enum UserRole {
  VENDOR
  PLANNER
  CLIENT
  ADMIN
}

enum BookingStatus {
  REQUESTED
  MEETING_PHASE_1
  CONFIRMATION_PENDING
  MEETING_PHASE_2
  CONFIRMED
  REJECTED_CAPACITY
  CANCELLED
  COMPLETED
}

enum StaffStatus {
  AVAILABLE
  ON_SITE
  ON_LEAVE
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DELAYED
}

// ── NEW ENUM ───────────────────────────────────────────────────────────────────
enum EventType {
  SINGLE
  MULTI_FUNCTION
}

// ── PLANNER STAFF ─────────────────────────────────────────────────────────────

enum PlannerStaffStatus {
  AVAILABLE
  BUSY
  ON_LEAVE
}

model PlannerStaff {
  id               String              @id @default(uuid())
  plannerProfileId String
  planner          PlannerProfile      @relation(fields: [plannerProfileId], references: [id], onDelete: Cascade)

  name             String
  role             String
  email            String?
  phone            String?
  status           PlannerStaffStatus  @default(AVAILABLE)
  assignedEvents   Int                 @default(0)

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  assignments      PlannerStaffAssignment[]

  @@index([plannerProfileId, status])
}

// ── PLANNER STAFF ASSIGNMENTS ─────────────────────────────────────────────────

model PlannerStaffAssignment {
  id        String       @id @default(uuid())
  staffId   String
  staff     PlannerStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event        @relation("StaffAssignments", fields: [eventId], references: [id], onDelete: Cascade)
  task      String?      // what they're responsible for e.g. "Coordinate catering"
  notes     String?
  createdAt DateTime     @default(now())

  @@unique([staffId, eventId])
  @@index([staffId])
  @@index([eventId])
}
